# Resource control policy requiring KMS encryption for tagged S3 buckets
# github.com/sqlxpert/aws-rcp-s3-require-encryption-kms
# GPLv3, Copyright Paul Marcelin

[MAIN]

load-plugins=pylint.extensions.no_self_use

[MESSAGES CONTROL]

disable=fixme,locally-disabled,duplicate-code

# duplicate-code
# Special case when multiple files, similar because the priority is simple
# AWS Lambda packaging, are evaluated together
# https://github.com/pylint-dev/pylint/issues/214

[REPORTS]

reports=no

[VARIABLES]

max-locals=25

[BASIC]

argument-rgx=[a-z_][a-z0-9_]{1,30}$
variable-rgx=[a-z_][a-z0-9_]{1,30}$

[FORMAT]

indent-string="    "
indent-after-paren=4
max-line-length=80
